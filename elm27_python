import bluetooth
import time

ELM327_MAC = "00:1D:A5:68:98:8B"  # troque pelo seu
PORT = 1

sock = bluetooth.BluetoothSocket(bluetooth.RFCOMM)

print("Conectando ao ELM327...")
sock.connect((ELM327_MAC, PORT))
print("Conectado!")

def send_command(cmd):
    sock.send((cmd + "\r").encode())
    time.sleep(0.5)
    data = sock.recv(1024).decode(errors="ignore")
    return data

# Inicialização básica do ELM327
print(send_command("ATZ"))   # Reset
print(send_command("ATE0"))  # Echo off
print(send_command("ATL0"))  # Linefeeds off
print(send_command("ATS0"))  # Spaces off
print(send_command("ATH0"))  # Headers off

# Exemplo: pedir RPM do motor
response = send_command("010C")
print("Resposta RPM:", response)

sock.close()

